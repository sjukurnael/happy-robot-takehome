# Copy to .env (gitignored) and fill in to enable the AI task breakdown:
#
#   cp .env.example .env
#
# Docker Compose reads .env automatically, so `make up` picks this up with
# no extra flags. Without a key the app is fully functional — only the
# "Break down with AI" button degrades to a clear "not configured" message.
ANTHROPIC_API_KEY=
